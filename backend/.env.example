# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-render-app.onrender.com/auth/google/callback

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Security
SECRET_KEY=generate-a-long-random-string
ENCRYPTION_KEY=generate-a-fernet-key-with-python

# URLs
FRONTEND_URL=https://your-vercel-app.vercel.app

# Database (set automatically by Render from the linked PostgreSQL database)
DATABASE_URL=postgresql://user:password@host/dbname

# Leave this unset in production (only for local dev over HTTP)
# OAUTHLIB_INSECURE_TRANSPORT=1
